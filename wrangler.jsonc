{
    "name": "api",
    "main": ".output/server/index.mjs",
    "compatibility_date": "2026-04-30",
    "assets": {
        "directory": "./output/public",
        "binding": "ASSETS"
    },
    "rules": [
        {
            "type": "ESModule",
            "globs": ["**/*.js", "**/*.mjs"]
        }
    ]
}